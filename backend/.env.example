# Server
PORT=3001

# Database (required). Supabase: Project Settings → Database → Connection string → URI.
# Example: postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or direct: postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Auth: long random string in production (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-in-production

# CORS: frontend origin(s) in production (e.g. https://your-app.vercel.app). Comma-separated for multiple.
# Required when deploying backend (e.g. Render) and frontend (e.g. Vercel) on different origins.
CORS_ORIGIN=

# Optional: cookie domain if you need to share cookie across subdomains. Usually leave unset.
# COOKIE_DOMAIN=

# AI tutor (POST /api/ai/chat). Leave empty to disable.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
